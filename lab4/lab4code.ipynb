import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import MinMaxScaler, StandardScaler
from sklearn.decomposition import PCA

sns.set(style="whitegrid")

# Load the KFC dataset
df = pd.read_csv("KFC_Past_Sales_Dataset.csv")
pd.set_option("display.max_columns", None)
df.head(10)

# 1.1 Check Data Types
print("Initial Data Types:\n", df.dtypes)

# 1.2 Convert Incorrect Data Types
# We convert Year and Month into a datetime object for time-based analysis
df['Date'] = pd.to_datetime(df['Year'].astype(str) + '-' + df['Month'], format='%Y-%b')

# Re-check types
print("\nUpdated Data Types:\n", df.dtypes)
df.head()

# 2.1 Detect Missing Values
print("Missing values per column:\n", df.isna().sum())

# 2.2 Demonstration: Introduce and Handle Artificial Missing Values
df_missing = df.copy()
# Introduce NaNs in the 'Sales' column for the first 10 rows
df_missing.loc[0:10, 'Sales'] = np.nan

# Strategy: Median Imputation (Preferred for sales data which often has outliers)
df_imputed = df_missing.copy()
df_imputed['Sales'] = df_imputed['Sales'].fillna(df_imputed['Sales'].median())

print("\nMissing values after Median Imputation:", df_imputed['Sales'].isna().sum())

# 3.1 Detect Outliers using IQR on 'Sales'
Q1 = df['Sales'].quantile(0.25)
Q3 = df['Sales'].quantile(0.75)
IQR = Q3 - Q1

lower_limit = Q1 - 1.5 * IQR
upper_limit = Q3 + 1.5 * IQR

outliers = df[(df['Sales'] < lower_limit) | (df['Sales'] > upper_limit)]
print(f"Number of outliers detected: {len(outliers)}")

# 3.2 Handle Outliers: Capping (Percentile Method)
df_capped = df.copy()
df_capped['Sales'] = df_capped['Sales'].clip(lower_limit, upper_limit)

# Visualize with Boxplot
plt.figure(figsize=(6,4))
sns.boxplot(x=df_capped['Sales'], color='salmon')
plt.title("Boxplot of KFC Sales (Capped)")
plt.show()

# Select numerical features
features = ['Sales', 'Customers', 'Marketing_Spend']
df_norm = df[features].copy()

# 4.1 Min-Max Normalization (Scales to 0-1)
min_max_scaler = MinMaxScaler()
df_minmax = pd.DataFrame(min_max_scaler.fit_transform(df_norm), columns=features)

# 4.2 Z-Score Normalization (Standardization: Mean=0, Std=1)
std_scaler = StandardScaler()
df_zscore = pd.DataFrame(std_scaler.fit_transform(df_norm), columns=features)

print("Z-Score Normalized Data (Head):\n", df_zscore.head())

# 5.1 Check Correlation before PCA
plt.figure(figsize=(6,4))
sns.heatmap(df_zscore.corr(), annot=True, cmap="Reds")
plt.title("Feature Correlation Heatmap")
plt.show()

# 5.2 Apply PCA
pca = PCA(n_components=2)
principal_components = pca.fit_transform(df_zscore)

print("Explained Variance Ratio:", pca.explained_variance_ratio_)

# 5.3 PCA Scatter Plot
plt.figure(figsize=(8,6))
plt.scatter(principal_components[:, 0], principal_components[:, 1], alpha=0.7, c='red', edgecolors='k')
plt.title("PCA Projection of KFC Sales Data")
plt.xlabel(f"PC1 ({pca.explained_variance_ratio_[0]:.2%} Variance)")
plt.ylabel(f"PC2 ({pca.explained_variance_ratio_[1]:.2%} Variance)")
plt.show()


